# Copy this to .env and fill in your values.
# For local dev with Docker MongoDB (docker-compose.yml), use the mongodb URL below.
# For MongoDB Atlas, replace with your Atlas connection string.

DB_URL=mongodb://localhost:27017
DB_NAME=updates
API_KEYS=dev-key-1
DEBUG_MODE=True
APP_MODE=dev
PORT=8000
HOST=0.0.0.0

# Optional frontend customization
# FRONTEND_TITLE=Farm Board
# FRONTEND_SHORTNAME=Farm Board
# FRONTEND_DESCRIPTION=Status board
# FRONTEND_POSTS_NAME=Posts
# FRONTEND_POST_LIMIT=250
# FRONTEND_BUILD_PATH=../frontend/build
